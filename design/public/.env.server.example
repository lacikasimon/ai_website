# Masold ezt a fajlt .env.server neven a szerverre.
#
# A legjobb hely:
# /home/CPANEL_USER/.env.server
#
# Ha a szolgaltato ezt nem engedi, akkor teheted ide is:
# /home/CPANEL_USER/public_html/.env.server
#
# Fontos: ezt NE nevezd .env.production-nak, es NE hasznalj VITE_ prefixet titkos adatokhoz.

# CRM webhook
CRM_LEAD_WEBHOOK_URL=https://app.m-sys.ro/crm/webhook/3/leads
CRM_WEBHOOK_KEY=IDE_IRD_A_CRM_WEBHOOK_KULCSOT

# Google reCAPTCHA secret key
# Ez NEM a site key. Ez a titkos kulcs a Google reCAPTCHA admin feluleterol.
RECAPTCHA_SECRET_KEY=IDE_IRD_A_RECAPTCHA_SECRET_KEYT

# MySQL / cPanel adatbazis
DB_HOST=localhost
DB_NAME=CPANELUSER_ADATBAZISNEV
DB_USER=CPANELUSER_DB_FELHASZNALO
DB_PASS=MYSQL_JELSZO
DB_CHARSET=utf8mb4
DB_TABLE_PREFIX=gs_

# Elso admin felhasznalo letrehozasa.
# Csak akkor hasznalja a rendszer, ha a gs_admin_users tabla meg ures.
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_DISPLAY_NAME=Administrator
ADMIN_SEED_PASSWORD=IDE_IRD_AZ_ERO_ADMIN_JELSZOT

# Admin fail-to-ban beallitasok
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_BAN_MINUTES=15
