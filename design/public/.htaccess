# GENE SYS SECURITY — Vite/React SPA (statikus build)
# Töltsd fel a dist/ teljes tartalmát (index.html, assets/, .htaccess egy szinten).

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Domain gyökér (public_html): RewriteBase /
  RewriteBase /
  # Alkönyvtár (pl. public_html/site/): kommenteld ki a fentit és:
  # RewriteBase /site/

  # Böngészők alap favicon.ico kérése → SVG (elkerüli a 404-et)
  RewriteRule ^favicon\.ico$ favicon.svg [L,NC]

  # Meglévő fájlok és mappák kiszolgálása
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . index.html [L]
</IfModule>

# Opcionális: gzip (ha a szerver engedi)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
