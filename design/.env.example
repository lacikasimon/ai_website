# URL public absolut al site-ului (fără slash final). Necessar pentru canonical, Open Graph, sitemap la build.
# Exemplu: VITE_SITE_URL=https://syshub.ro
VITE_SITE_URL=https://syshub.ro

# Google Search Console: folosiți valoarea din meta tag-ul primit de la Google.
# Exemplu: <meta name="google-site-verification" content="abc123" /> -> VITE_GOOGLE_SITE_VERIFICATION=abc123
VITE_GOOGLE_SITE_VERIFICATION=

# PIN pentru interfața minimă /admin. Pe site static acesta nu înlocuiește autentificarea de backend.
VITE_ADMIN_PIN=1234

# Protecție login locală: după 5 încercări greșite, username-ul este blocat 15 minute în browser.
VITE_ADMIN_MAX_FAILED_ATTEMPTS=5
VITE_ADMIN_BAN_MINUTES=15
# Fallback admin local doar pentru test. În producție lăsați false; adminul real folosește PHP/MySQL.
VITE_ENABLE_LOCAL_ADMIN=false

# Google reCAPTCHA v2 site key. Secret key-ul se verifică doar pe backend.
VITE_RECAPTCHA_SITE_KEY=

# Endpoint intern pentru formularul de contact. În build-ul Apache/cPanel acesta ajunge în dist/admin/contact-lead.php.
VITE_CONTACT_LEAD_ENDPOINT=/admin/contact-lead.php
VITE_CONTACT_LEAD_CAMPAIGN=syshub_ro_contact

# Endpointuri interne pentru CMS/admin pe Apache/cPanel.
VITE_CMS_ENDPOINT=/admin/cms.php
VITE_ADMIN_ENDPOINT=/admin/admin.php

# Variabile SERVER-SIDE pentru PHP.
# Nu folosiți prefixul VITE_ pentru valori secrete.
# Pe cPanel, puneți aceste valori ca environment variables sau într-un fișier .env.server în afara public_html.
# CRM_WEBHOOK_KEY = doar cheia, fără „Bearer”, „Authorization:” sau „X-CRM-Webhook-Key:”.
CRM_LEAD_WEBHOOK_URL=https://app.m-sys.ro/crm/webhook/3/leads
# authorization = Authorization: Bearer, x-key = X-CRM-Webhook-Key, both = ambele.
CRM_AUTH_MODE=authorization
CRM_WEBHOOK_KEY=
RECAPTCHA_SECRET_KEY=

# MySQL opțional pentru Apache/cPanel. Dacă aceste valori lipsesc, formularul trimite doar spre CRM.
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4
DB_TABLE_PREFIX=gs_

# Seed admin SERVER-SIDE pentru primul cont MySQL. Completați parola o singură dată înainte de prima autentificare.
# După ce contul există în baza de date, această valoare nu mai schimbă parola.
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_DISPLAY_NAME=Administrator
ADMIN_SEED_PASSWORD=
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_BAN_MINUTES=15
